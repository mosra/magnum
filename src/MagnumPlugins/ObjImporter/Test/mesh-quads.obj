# A house.
#
#    1
#   / \
#  /   \
# 2 --- 5
# |     |
# |     |
# 3 --- 4

v 0 3 0
v -1 1 0
v -1 -1 0
v 1 -1 0
v 1 1 0

vt 0.5 1
vt 0 0.5
vt 0 0
vt 1 0
vt 1 0.5

# Normals of the roof are pointing up, to the left and to the right
vn 0 1 0
vn -1 0 0
vn 1 0 0
f 1/1/1 2/2/2 5/5/3

# Normals of the walls are all pointing down
vn 0 -1 0
f 2/2/4 3/3/4 4/4/4 5/5/4
